{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "email": { "type": "string", "format": "email", "description": "User's email" },
        "role": { "type": "string", "enum": ["user", "moderator", "admin"], "description": "User's role" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Slang": {
      "title": "Slang",
      "description": "A Myanmar slang word entry",
      "type": "object",
      "properties": {
        "word": { "type": "string", "description": "The slang word" },
        "pronunciation": { "type": "string", "description": "English pronunciation of the slang" },
        "meaning": { "type": "string", "description": "The meaning of the slang in English" },
        "meaningBurmese": { "type": "string", "description": "The meaning of the slang in Burmese" },
        "examples": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "Examples of usage" 
        },
        "authorId": { "type": "string", "description": "UID of the user who submitted" },
        "authorName": { "type": "string", "description": "Name of the user who submitted" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Moderation status" },
        "upvotes": { "type": "number", "description": "Number of upvotes" },
        "downvotes": { "type": "number", "description": "Number of downvotes" },
        "views": { "type": "number", "description": "Number of views" },
        "viewHistory": { "type": "object", "description": "Daily view counts" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["word", "meaning", "authorId", "status", "upvotes", "downvotes", "createdAt", "updatedAt"]
    },
    "Vote": {
      "title": "Vote",
      "description": "A user's vote on a slang",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "slangId": { "type": "string" },
        "voteType": { "type": "string", "enum": ["up", "down"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "slangId", "voteType", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/slangs/{slangId}": {
      "schema": { "$ref": "#/entities/Slang" },
      "description": "Stores slang entries"
    },
    "/votes/{voteId}": {
      "schema": { "$ref": "#/entities/Vote" },
      "description": "Stores user votes on slangs. Document ID should be {userId}_{slangId}"
    }
  }
}
